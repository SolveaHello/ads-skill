# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit it.

# Google Ads Developer Token
# Where to get: Google Ads → Tools & Settings → API Center
ADS_DEVELOPER_TOKEN=your-developer-token-here

# OAuth2 App credentials (from Google Cloud Console → APIs & Services → Credentials)
# App type must be "Desktop app"
# Authorized redirect URI must include: http://localhost:8086/callback
ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
ADS_CLIENT_SECRET=GOCSPX-your-client-secret

# Optional: override the OAuth2 callback port (default: 8086)
# ADS_REDIRECT_URI=http://localhost:8086/callback
